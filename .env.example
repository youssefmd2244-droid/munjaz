# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_API_KEY_2 (optional): A second/backup Gemini API key.
# If the first key hits a quota limit or errors out, the server
# automatically retries the request with this key instead.
# You can also add GEMINI_API_KEY_3, or a comma-separated GEMINI_API_KEYS
# list, for even more fallback keys.
GEMINI_API_KEY_2="MY_BACKUP_GEMINI_API_KEY"

# OPENROUTER_API_KEY (optional): Used as the next fallback provider after
# every Gemini key has been tried and failed. Get a key at openrouter.ai/keys
# You can add OPENROUTER_API_KEY_2 or a comma-separated OPENROUTER_API_KEYS
# list for more fallback keys on this provider too.
OPENROUTER_API_KEY="MY_OPENROUTER_API_KEY"

# OPENROUTER_MODEL (optional): which model OpenRouter should route to.
# Defaults to "openai/gpt-4o-mini" if not set. Browse models at
# openrouter.ai/models
OPENROUTER_MODEL="openai/gpt-4o-mini"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
